{
  "name": "waymark",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "ios": "expo run:ios",
    "prebuild": "expo prebuild --clean",
    "build:ios:dev": "eas build --profile development --platform ios",
    "build:ios:preview": "eas build --profile preview --platform ios",
    "build:ios:prod": "eas build --profile production --platform ios",
    "submit:ios": "eas submit --platform ios",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:rules": "npm --prefix firestore-tests test",
    "test:e2e": "maestro test .maestro",
    "test:e2e:launch": "maestro test .maestro/smoke-launch.yaml",
    "test:e2e:login": "maestro test .maestro/smoke-anon-login.yaml",
    "android": "expo run:android",
    "postinstall": "patch-package",
    "emulator:start": "firebase emulators:start --only auth,firestore,functions,storage",
    "emulator:seed": "FIRESTORE_EMULATOR_HOST=localhost:8080 FIREBASE_AUTH_EMULATOR_HOST=localhost:9099 tsx scripts/seed-emulator.ts",
    "dev:emulator": "EXPO_PUBLIC_USE_EMULATOR=1 expo start"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.11",
    "expo": "~54.0.33",
    "expo-apple-authentication": "~8.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-clipboard": "~8.0.7",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-file-system": "~19.0.14",
    "expo-font": "~14.0.12",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.8",
    "expo-linking": "^57.0.1",
    "expo-location": "~19.0.8",
    "expo-share-intent": "^5.1.1",
    "expo-status-bar": "~3.0.9",
    "expo-video-thumbnails": "~10.0.8",
    "firebase": "^12.12.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-map-clustering": "^4.0.0",
    "react-native-maps": "1.24.11",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.0",
    "firebase-admin": "^14.1.0",
    "jest": "^30.4.1",
    "patch-package": "^8.0.1",
    "postinstall-postinstall": "^2.1.0",
    "ts-jest": "^29.4.11",
    "tsx": "^4.23.0",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "jest-environment-node": "^30.4.1",
    "jest-mock": "^30.4.1"
  },
  "private": true
}
