rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // A user can only read/write their own subtree.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Public profile read (#11). Any authenticated user can read a user doc
    // when the owner's profile is public. This powers UserProfileScreen and
    // the exact-match SearchUsersScreen (query filters on `isPublic == true`,
    // which the rule engine verifies against `resource.data.isPublic`).
    match /users/{userId} {
      allow read: if request.auth != null && resource.data.isPublic == true;
    }

    // Public read of a user's lieux (#11). Any authenticated user can list
    // and read the lieux of a public owner. We resolve `isPublic` from the
    // parent user doc via `get()` — memoized within a single rule evaluation,
    // so it's one extra doc read per query, not per pin.
    match /users/{userId}/lieux/{lieuId} {
      allow read: if request.auth != null
        && get(/databases/$(database)/documents/users/$(userId)).data.isPublic == true;
    }

    // Blocks — Apple guideline 1.2 (see #15). Explicit rule kept here even
    // though the wildcard above already covers it, so a future edit that
    // opens up read on `users/{uid}/*` for public profiles can't accidentally
    // leak someone's block list.
    match /users/{userId}/blocks/{blockedUid} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Follower / following sub-collections (#12).
    //
    // A follow is two symmetric writes committed as a single client-side batch:
    //   users/{followedUid}/followers/{followerUid}  ← written BY the follower
    //   users/{followerUid}/following/{followedUid}  ← written BY the follower
    // The wildcard rule at the top would deny the first write (the caller isn't
    // the owner of the parent user doc), so we need an explicit rule that lets
    // an authenticated caller add THEMSELVES to another user's followers list.
    //
    // Unfollow (delete) is allowed to either party: the follower (undo my
    // follow) or the followed user (remove an unwanted follower).
    match /users/{userId}/followers/{followerUid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.auth.uid == followerUid
                    && request.resource.data.keys().hasOnly(['createdAt']);
      allow delete: if request.auth != null
                    && (request.auth.uid == followerUid || request.auth.uid == userId);
    }

    // `following/{followedUid}` — owner-side write only. Symmetric to the
    // above from the follower's perspective. The wildcard already covers this
    // but we spell it out so the invariant is discoverable next to the
    // followers rule.
    match /users/{userId}/following/{followedUid} {
      allow read: if request.auth != null;
      allow create, delete: if request.auth != null && request.auth.uid == userId;
    }

    // Username uniqueness lock. `usernames/{lowercase}` maps a taken handle
    // to its owner uid. Reads are open so any authenticated client can check
    // availability. Creates require the caller to own the mapping and match
    // the client-side regex — this makes race-condition username squatting
    // impossible even for a hand-crafted request.
    match /usernames/{name} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.uid
        && name.matches('^[a-z0-9._]{3,20}$');
      allow delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
    }

    // Reports — Apple guideline 1.2 (see #15). Any authenticated user can
    // create a report, nobody can read/list them from the client. Reads happen
    // exclusively via the Admin SDK in a Cloud Function that relays each new
    // report to a private Slack channel for manual review.
    match /reports/{reportId} {
      allow create: if request.auth != null
                    && request.resource.data.reporterUid == request.auth.uid;
      allow read, update, delete: if false;
    }

    // Server-only: Apple Sign In refresh tokens for the revoke flow.
    // Default-deny would catch unmatched paths already; kept explicit so nobody
    // "helpfully" opens this up later without noticing the sensitivity.
    match /appleAuth/{userId} {
      allow read, write: if false;
    }
  }
}
