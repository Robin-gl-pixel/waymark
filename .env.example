# Firebase (mappies-app project)
# Récupère ces valeurs dans Firebase Console → Project settings → General → Your apps → Web app
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=mappies-app.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=mappies-app
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=mappies-app.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Backend only (Cloud Functions) — ne pas exposer côté app
# ANTHROPIC_API_KEY=
# MAPBOX_SECRET_TOKEN=
