rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Screenshots live under a user-scoped path — only that user can read/write.
    // DEPRECATED path — kept for read-compat with pre-#35 pins. New pins use
    // `users/{uid}/photos/{lieuId}/{photoId}.jpg` (see rule below).
    match /users/{userId}/screenshots/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Multi-photo gallery per pin (#35 + #38). One user, one lieuId per
    // folder, arbitrary photoId as the leaf. Same owner-only invariant.
    match /users/{userId}/photos/{lieuId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
