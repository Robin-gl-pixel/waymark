rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Legacy pre-migration path: single screenshot per pin. Kept for read
    // compatibility with pins created before the photos[] migration
    // (parent PRD #34 / slice #35). New pins write under `photos/…` instead.
    match /users/{userId}/screenshots/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Gallery photos, post-migration layout:
    //   users/{uid}/photos/{lieuId}/{photoId}.jpg
    // Owner-scoped read/write, matching the screenshots rule above.
    match /users/{userId}/photos/{lieuId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
